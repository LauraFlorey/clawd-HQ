# ─── Gateway Connections ─────────────────────────────────────────
# Primary gateway — use localhost when running on the same machine
VITE_GATEWAY_1_HOST=localhost
VITE_GATEWAY_1_PORT=18789
VITE_GATEWAY_1_TOKEN=

# Secondary gateway — use hostname or IP of a remote machine
VITE_GATEWAY_2_HOST=remote-host.example
VITE_GATEWAY_2_PORT=18789
VITE_GATEWAY_2_TOKEN=

# ─── Anthropic Admin API ────────────────────────────────────────
# Get from: console.anthropic.com → Settings → Admin API Keys
# This is an ADMIN key, not a regular API key
ANTHROPIC_ADMIN_KEY=

# ─── Proxy Server ───────────────────────────────────────────────
PROXY_PORT=3001

# ─── Dashboard ──────────────────────────────────────────────────
VITE_PROXY_URL=http://localhost:3001
