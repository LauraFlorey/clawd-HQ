{
  "name": "openclaw-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"vite --port 3000 --strictPort\" \"node --env-file=.env.local src/server/proxy.js\"",
    "dev:ui": "vite",
    "dev:server": "node --env-file=.env.local src/server/proxy.js",
    "build": "vite build",
    "preview": "concurrently \"vite preview\" \"node --env-file=.env.local src/server/proxy.js\"",
    "start": "concurrently \"vite preview\" \"NODE_ENV=production node --env-file=.env.local src/server/proxy.js\""
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.0.6",
    "vite": "^6.1.0"
  }
}
